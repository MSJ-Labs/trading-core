,env# Copy this file to .env and fill in the values.
# .env is gitignored and never committed.

# For local dev — use application-local.properties instead (see README).
# Required in prod — HS512 JWT signing secret, minimum 512 bits (64 bytes base64-encoded)
# Generate with: openssl rand -base64 64
JWT_SECRET=

# Optional — override token lifetimes (milliseconds)
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Optional — CoinGecko Demo API key (free at coingecko.com/api)
# Leave empty to use the unauthenticated public endpoint (rate-limited)
COINGECKO_API_KEY=

# Production only — set when deploying over HTTPS
COOKIE_SECURE=false
COOKIE_DOMAIN=
