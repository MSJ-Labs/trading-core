# Copy this file to secret.yaml (gitignored) and fill in real values.
# Generate a JWT secret with: openssl rand -base64 64
apiVersion: v1
kind: Secret
metadata:
  name: trading-core-secret
type: Opaque
stringData:
  JWT_SECRET: REPLACE_WITH_YOUR_SECRET
  SPRING_DATASOURCE_USERNAME: postgres
  SPRING_DATASOURCE_PASSWORD: REPLACE_WITH_YOUR_PASSWORD